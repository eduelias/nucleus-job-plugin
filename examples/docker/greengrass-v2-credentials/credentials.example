# AWS credentials for provisioning ONLY. Copy to `credentials` in this folder.
#
# The installer uses these to create the thing / thing group / IAM role+alias.
# After provisioning you can remove them (see README / teardown.sh) — the running
# device uses the token-exchange role, not these keys.
#
# Prefer short-lived credentials for an IAM role (include aws_session_token).

[default]
aws_access_key_id = YOUR_ACCESS_KEY_ID
aws_secret_access_key = YOUR_SECRET_ACCESS_KEY
# aws_session_token = YOUR_SESSION_TOKEN   # required for temporary credentials
