# Environment for the Greengrass nucleus container (automatic provisioning).
# Copy to `.env` and adjust. run-demo.sh fills THING_NAME/THING_GROUP_NAME with a
# random suffix automatically if you leave the *-REPLACE placeholders.

# Greengrass root inside the container.
GGC_ROOT_PATH=/greengrass/v2

# AWS region to provision in / target.
AWS_REGION=us-east-1

# Automatically provision the thing, thing group, IAM role and role alias.
PROVISION=true

# Ephemeral demo resource names. run-demo.sh replaces the *-REPLACE placeholders
# with a random suffix (e.g. njp-demo-ab12cd) so repeated runs don't collide and
# teardown.sh can clean them up safely.
THING_NAME=njp-demo-REPLACE
THING_GROUP_NAME=njp-demo-group-REPLACE

# Token exchange role + alias (shared name is fine; created if missing).
TES_ROLE_NAME=GreengrassV2TokenExchangeRole
TES_ROLE_ALIAS_NAME=GreengrassCoreTokenExchangeRoleAlias

# Component run user/group inside the container.
COMPONENT_DEFAULT_USER=ggc_user:ggc_group

# Install the Greengrass CLI (aws.greengrass.Cli) so the demo can deploy the
# component locally without S3 or a cloud component version. Dev-tools only.
DEPLOY_DEV_TOOLS=true
