{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "dev.du7.nucleus-job-plugin",
  "ComponentVersion": "{COMPONENT_VERSION}",
  "ComponentType": "aws.greengrass.generic",
  "ComponentDescription": "Unofficial Rust runner for AWS IoT Jobs execution, incl. AWS managed job templates (community, not affiliated with Amazon).",
  "ComponentPublisher": "eduelias",
  "ComponentDependencies": {
    "aws.greengrass.Nucleus": {
      "VersionRequirement": ">=2.0.0 <3.0.0",
      "DependencyType": "SOFT"
    }
  },
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "logLevel": "info",
      "handlerDir": "/var/lib/nucleus-job-plugin/handlers",
      "jobTimeoutSecs": "300",
      "includeStdout": "1",
      "installSampleHandlers": "1",
      "transport": "ipc",
      "accessControl": {
        "aws.greengrass.ipc.mqttproxy": {
          "dev.du7.nucleus-job-plugin:mqttproxy:1": {
            "policyDescription": "Allow the runner to speak the reserved IoT Jobs topics for this thing.",
            "operations": [
              "aws.greengrass#PublishToIoTCore",
              "aws.greengrass#SubscribeToIoTCore"
            ],
            "resources": [
              "$aws/things/${iot:thingName}/jobs/*",
              "$aws/things/${iot:thingName}/jobs/#"
            ]
          }
        }
      }
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux"
      },
      "Lifecycle": {
        "Install": {
          "RequiresPrivilege": true,
          "Script": "/usr/bin/bash {artifacts:path}/setup.sh {artifacts:path} {configuration:/handlerDir} {configuration:/installSampleHandlers} {artifacts:decompressedPath}/handlers/handlers"
        },
        "Startup": {
          "RequiresPrivilege": true,
          "Setenv": {
            "RUST_LOG": "nucleus_job_plugin={configuration:/logLevel}",
            "THING_NAME": "{iot:thingName}",
            "HANDLER_DIR": "{configuration:/handlerDir}",
            "JOB_TIMEOUT_SECS": "{configuration:/jobTimeoutSecs}",
            "INCLUDE_STDOUT": "{configuration:/includeStdout}",
            "TRANSPORT": "{configuration:/transport}"
          },
          "Script": "/usr/local/bin/nucleus-job-plugin"
        }
      },
      "Artifacts": [
        {
          "Uri": "s3://BUCKET_NAME/dev.du7.nucleus-job-plugin/COMPONENT_VERSION/nucleus-job-plugin",
          "Permission": { "Read": "ALL", "Execute": "ALL" }
        },
        {
          "Uri": "s3://BUCKET_NAME/dev.du7.nucleus-job-plugin/COMPONENT_VERSION/setup.sh",
          "Permission": { "Read": "ALL" }
        },
        {
          "Uri": "s3://BUCKET_NAME/dev.du7.nucleus-job-plugin/COMPONENT_VERSION/handlers.zip",
          "Unarchive": "ZIP",
          "Permission": { "Read": "ALL", "Execute": "ALL" }
        }
      ]
    }
  ]
}
